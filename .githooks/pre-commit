#!/bin/sh
#
# pre-commit hook — keep the footer "Last Updated M.YYYY" stamp current.
#
# On every commit this rewrites "Last Updated <month>.<year>" in the site's
# HTML files to the current month/year, then stages any file it changed so the
# update rides along in the same commit. If the stamp is already current it
# does nothing.
#
# Portable on purpose: only needs sh, date, and sed (works on macOS + Linux),
# so it keeps working on any machine that clones the repo.

# Always operate from the repository root, regardless of where git invokes us.
cd "$(git rev-parse --show-toplevel)" || exit 1

# Current month with no leading zero (07 -> 7, 12 -> 12) and 4-digit year.
MONTH=$(date +%m | sed 's/^0*//')
YEAR=$(date +%Y)
STAMP="${MONTH}.${YEAR}"

FILES="index.html about.html math-center.html lab.html"
CHANGED=""

for f in $FILES; do
    [ -f "$f" ] || continue

    # Replace "Last Updated N.NNNN" (basic regex works the same in BSD & GNU sed).
    sed "s/Last Updated [0-9]\{1,2\}\.[0-9]\{4\}/Last Updated ${STAMP}/g" "$f" > "$f.tmp" \
        && mv "$f.tmp" "$f"

    # If git sees a content change, stage it so it's part of this commit.
    if ! git diff --quiet -- "$f"; then
        git add "$f"
        CHANGED="${CHANGED} $f"
    fi
done

if [ -n "$CHANGED" ]; then
    echo "pre-commit: set 'Last Updated' to ${STAMP} in:${CHANGED}"
fi

exit 0
